# Copy this file to .env.local and set your values.

# Site base URL (required for sitemap, robots.txt, and canonical URLs). Use your production URL.
# NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Affiliate link configuration (required for real "Watch Full Video" links)

# Base URL for outbound affiliate links (no trailing slash).
# Currently using Chaturbate Revshare Home Page link.
# Example: https://chaturbate.com/in/?tour=grq0&campaign=0roTN&track=default
# Or use Datify.Link SmartLink: https://luckynowforever.com/CBWqCN9Z?aid=...
NEXT_PUBLIC_AFFILIATE_BASE_URL=https://chaturbate.com/in/?tour=grq0&campaign=0roTN&track=default

# Optional: add these to track campaign/source/medium in your affiliate dashboard
# NEXT_PUBLIC_AFFILIATE_CAMPAIGN=streamhub
# NEXT_PUBLIC_AFFILIATE_SOURCE=web
# NEXT_PUBLIC_AFFILIATE_MEDIUM=affiliate

# Optional: Dating affiliate URL for smart rotation (GEO + device). When set, main CTA rotates among Chaturbate, Dating, Webcam.
# NEXT_PUBLIC_AFFILIATE_DATING_URL=https://example-dating.com/ref/xxx

# Optional: Webcam affiliate URL (e.g. Stripchat, BongaCams) for smart rotation.
# NEXT_PUBLIC_AFFILIATE_WEBCAM_URL=https://example-webcam.com/ref/xxx

# Optional: Google Analytics 4 measurement ID for page views and "Watch Full Video" clicks.
# Set to enable analytics; disclosed in Privacy Policy. Leave unset to disable tracking.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-Y3D5TCY246

# Optional: OneSignal App ID for web push notifications (free at onesignal.com).
# When set, a bell icon appears in the header. Users can subscribe for:
#   - New videos / new blog posts
#   - Trending videos (schedule from OneSignal dashboard)
#   - Night traffic (schedule evening sends in dashboard)
# Add OneSignalSDKWorker.js to public/ (included). Configure site URL in OneSignal dashboard.
# NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Optional: Adsterra Effective Gate CPM URL – shown on video pages only. Leave unset to hide.
# NEXT_PUBLIC_ADSTERRA_GATE_URL=https://www.effectivegatecpm.com/kk41qkf0ax?key=4e25a83ed814eba20db141501776e30b

# Optional: Lovense affiliate store link. "Shop Lovense" appears on video pages. Default: https://www.lovense.com/r/g5oi41
# NEXT_PUBLIC_LOVENSE_AFFILIATE_URL=https://www.lovense.com/r/g5oi41

# Optional: AdultForce ad slots (Brazzers, Bangbros, etc.). Leave unset to use default slot IDs.
# NEXT_PUBLIC_ADULTFORCE_PREROLL=https://a.adtng.com/get/10016607
# NEXT_PUBLIC_ADULTFORCE_BANNER_950=https://a.adtng.com/get/10016608
# NEXT_PUBLIC_ADULTFORCE_BOX_300=https://a.adtng.com/get/10016609
# NEXT_PUBLIC_ADULTFORCE_BANNER_728=https://a.adtng.com/get/10016610
